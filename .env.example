# Super AI Transcript - Environment Configuration Template
# =====================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# ---- API KEYS ----

# GEMINI API KEY (for AI text processing)
# Get FREE at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: enable local Whisper transcription inside Docker
WHISPER_LOCAL=1
WHISPER_MODEL=small

# ---- MySQL DATABASE CONFIGURATION ----
# These settings connect your app to MySQL
# See setup guide: MYSQL_SETUP.md

# MySQL host (localhost for local development)
DB_HOST=localhost

# MySQL username (default is 'root' after installation)
DB_USER=root

# MySQL password (set during MySQL installation)
# Leave empty if no password set (development only)
DB_PASSWORD=

# Database name (will be created if doesn't exist)
DB_NAME=super_ai_transcript

# ---- FLASK CONFIGURATION ----

# Port to run the server on
# Local: 5000
# Hugging Face Spaces: 7860 (auto-configured)
PORT=5000
